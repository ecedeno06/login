{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES5",
    "module": "commonjs",
    "baseUrl": "./",
    "paths": {
      "@image/*": ["image/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["typeScript/**/*", "src/**/*"]
}
